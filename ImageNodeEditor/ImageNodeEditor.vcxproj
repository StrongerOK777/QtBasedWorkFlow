<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <!--
    原生 Visual Studio 2026 工程：由 VS/MSVC 直接编译 ImageNodeEditor 的源码。
    - Qt 的 moc/rcc 产物已预生成在 GeneratedFiles\（改了 Q_OBJECT 头或 qml 后运行 GeneratedFiles\regen.bat 刷新）。
    - 第三方 QtNodes 以预编译静态库 third_party\QtNodes\lib\QtNodes.lib 链接（非本项目源码）。
    - 仅 Release|x64（本机只装了 Release 版 Qt）。跨平台仍以根目录 CMakeLists.txt 为准。
    Qt 路径用属性 QtDir，默认 C:\Qt\6.8.3\msvc2022_64，可用环境变量 QTDIR 覆盖。
  -->
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>
  <PropertyGroup Label="Globals">
    <VCProjectVersion>17.0</VCProjectVersion>
    <ProjectGuid>{2F8E9A1B-7C3D-4E5F-A6B7-C8D9E0F1A2B3}</ProjectGuid>
    <RootNamespace>ImageNodeEditor</RootNamespace>
    <WindowsTargetPlatformVersion>10.0.26100.0</WindowsTargetPlatformVersion>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'" Label="Configuration">
    <ConfigurationType>Application</ConfigurationType>
    <UseDebugLibraries>false</UseDebugLibraries>
    <PlatformToolset>v145</PlatformToolset>
    <WholeProgramOptimization>false</WholeProgramOptimization>
    <CharacterSet>Unicode</CharacterSet>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />
  <PropertyGroup Label="QtBasedWorkFlowLocal">
    <QtDir Condition="'$(QtDir)'==''">$(QTDIR)</QtDir>
    <QtDir Condition="'$(QtDir)'==''">C:\Qt\6.8.3\msvc2022_64</QtDir>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <OutDir>$(SolutionDir)out\$(Configuration)\</OutDir>
    <IntDir>$(SolutionDir)out\$(Configuration)\obj\</IntDir>
    <TargetName>ImageNodeEditor</TargetName>
  </PropertyGroup>
  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <ClCompile>
      <LanguageStandard>stdcpp17</LanguageStandard>
      <ConformanceMode>true</ConformanceMode>
      <AdditionalOptions>/Zc:__cplusplus /utf-8 %(AdditionalOptions)</AdditionalOptions>
      <WarningLevel>Level3</WarningLevel>
      <Optimization>MaxSpeed</Optimization>
      <FunctionLevelLinking>true</FunctionLevelLinking>
      <IntrinsicFunctions>true</IntrinsicFunctions>
      <RuntimeLibrary>MultiThreadedDLL</RuntimeLibrary>
      <MultiProcessorCompilation>true</MultiProcessorCompilation>
      <AdditionalIncludeDirectories>$(ProjectDir);$(ProjectDir)..\third_party\QtNodes\include;$(QtDir)\include;$(QtDir)\include\QtCore;$(QtDir)\include\QtGui;$(QtDir)\include\QtWidgets;$(QtDir)\include\QtOpenGL;$(QtDir)\include\QtQml;$(QtDir)\include\QtQuick;$(QtDir)\include\QtQuickControls2;$(QtDir)\include\QtQuickWidgets;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <PreprocessorDefinitions>WIN32;_WINDOWS;NDEBUG;QT_NO_DEBUG;UNICODE;_UNICODE;NODE_EDITOR_STATIC;QT_CORE_LIB;QT_GUI_LIB;QT_WIDGETS_LIB;QT_OPENGL_LIB;QT_QML_LIB;QT_QUICK_LIB;QT_QUICKCONTROLS2_LIB;QT_QUICKWIDGETS_LIB;%(PreprocessorDefinitions)</PreprocessorDefinitions>
    </ClCompile>
    <Link>
      <SubSystem>Windows</SubSystem>
      <GenerateDebugInformation>true</GenerateDebugInformation>
      <EnableCOMDATFolding>true</EnableCOMDATFolding>
      <OptimizeReferences>true</OptimizeReferences>
      <AdditionalLibraryDirectories>$(QtDir)\lib;$(ProjectDir)..\third_party\QtNodes\prebuilt;%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
      <AdditionalDependencies>Qt6Core.lib;Qt6Gui.lib;Qt6Widgets.lib;Qt6OpenGL.lib;Qt6Qml.lib;Qt6Quick.lib;Qt6QuickControls2.lib;Qt6QuickWidgets.lib;Qt6EntryPoint.lib;QtNodes.lib;%(AdditionalDependencies)</AdditionalDependencies>
      <!-- QtNodes 是静态库，其内置默认样式资源的自注册需整库链接才不会被裁掉。 -->
      <AdditionalOptions>/WHOLEARCHIVE:QtNodes.lib %(AdditionalOptions)</AdditionalOptions>
    </Link>
    <PostBuildEvent>
      <!-- 链接完成后用 windeployqt 把 Qt6 运行库、平台插件以及 Qt Quick/QML 模块复制到 exe 旁，
           保证 F5 调试与双击 exe 都能直接运行。qmldir 选项指向 qml 源码目录：windeployqt
           据此扫描 import，部署 QtQuick / Controls / Layouts / QtQml 等 QML 模块；缺这一步
           工作台侧边栏会因找不到 QML 模块而显示黑屏。 -->
      <Command>"$(QtDir)\bin\windeployqt.exe" --release --no-translations --no-compiler-runtime --qmldir "$(ProjectDir)qml" "$(OutDir)ImageNodeEditor.exe"</Command>
      <Message>windeployqt：部署 Qt 运行库与 QML 模块到 $(OutDir)</Message>
    </PostBuildEvent>
  </ItemDefinitionGroup>
